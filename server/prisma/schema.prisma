generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workout {
  id        String     @id @default(uuid())
  name      String
  date      String
  notes     String     @default("")
  createdAt DateTime   @default(now())
  exercises Exercise[]
}

model Exercise {
  id        String  @id @default(uuid())
  workoutId String
  workout   Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name      String
  sets      Int?
  reps      Int?
  weight    Float?
  order     Int     @default(0)
}
