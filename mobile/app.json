{
  "expo": {
    "name": "Personal Gym",
    "slug": "personal-gym",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0f0f0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.personal.gym"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0f0f"
      },
      "package": "com.personal.gym"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "scheme": "personalgym",
    "experiments": {
      "typedRoutes": true
    }
  }
}
